//@version=6
indicator("Tydeflow Flow - Institutional Footprint Scoring",
     shorttitle = "TF Flow", overlay = false,
     max_boxes_count = 50, max_labels_count = 100, max_lines_count = 50)

// --- INPUTS ---───────────────────────────────────────────────────────────────
var string GS = "Style"
var string GN = "Sensitivity"
var string GF = "Footprint detectors"
var string GV = "Visual options"
var string GA = "Alerts"

i_style  = input.string("Swing (3-30 day)", "Style preset",
     options = ["Swing (3-30 day)", "Position (1-6 month)", "Custom"],
     group = GS)
i_sens   = input.string("Balanced", "Sensitivity",
     options = ["Conservative", "Balanced", "Aggressive"], group = GN)
i_abs    = input.bool(true, "Volume Absorption",            group = GF)
i_eod    = input.bool(true, "End-of-Day Volume Surge",      group = GF)
i_vwap   = input.bool(true, "VWAP Magnetism",               group = GF)
i_vap    = input.bool(true, "Volume-at-Price Clustering",   group = GF)
i_orn    = input.bool(true, "Opening Range Stuffing",       group = GF)
i_tick   = input.bool(true, "Up/Down Tick Volume Imbalance", group = GF)
i_shosc  = input.bool(true, "Show oscillator panel", group = GV)
i_shzon  = input.bool(true, "Show entry zones",      group = GV)
i_shdsh  = input.bool(true, "Show dashboard",        group = GV)
i_dpos   = input.string("top-right", "Dashboard position",
     options = ["top-right","top-left","bottom-right","bottom-left"],
     group = GV)
i_theme  = input.string("dark", "Color theme",
     options = ["dark", "light"], group = GV)
i_alent  = input.bool(true,  "Alert on ENTRY signal", group = GA)
i_alex   = input.bool(true,  "Alert on EXIT signal",  group = GA)
i_alst   = input.bool(false, "Alert on state change", group = GA)

// --- COLORS ---───────────────────────────────────────────────────────────────
dk = i_theme == "dark"
C_BG   = dk ? color.new(#0a0a0a, 15) : color.new(#f7f7f7, 15)
C_PRI  = dk ? #ffffff : #1a1a1a
C_SEC  = dk ? #9b9b9b : #5a5a5a
C_TER  = dk ? #6b6b6b : #8a8a8a
C_BULL = #ff6b1a
C_BEAR = #3a3a3a
C_HAIR = dk ? #2a2a2a : #d4d4d4
C_HP   = #ff6b1a
C_HN   = #4a4a4a
C_ZHI  = color.new(#ff6b1a, 80)
C_ZMD  = color.new(#ff6b1a, 88)
C_ZBD  = #ff6b1a
C_ZBH  = color.new(#3a3a3a, 70)
C_ZBM  = color.new(#3a3a3a, 82)

// --- WEIGHTS & THRESHOLDS ---─────────────────────────────────────────────────
fmul = i_style == "Swing (3-30 day)" ? 1.10 : 1.00
cmul = i_style == "Swing (3-30 day)" ? 0.85 : 1.00
WA = 1.2 * fmul
WE = 1.0 * fmul
WV = 1.1 * fmul
WP = 1.0 * fmul
WO = 0.9 * fmul
WT = 1.3 * fmul

ethr = i_sens == "Conservative" ? 70.0 : i_sens == "Aggressive" ? 50.0 : 60.0
wthr = ethr - 20.0
xthr = -ethr
cthr = -wthr

// --- CONFLUENCE ---───────────────────────────────────────────────────────────
ma50  = ta.sma(close, 50)
ma200 = ta.sma(close, 200)

t_stk = close > ma50 and ma50 > ma200
t_50  = close > ma50 and not (ma50 > ma200)
t_200 = close > ma200 and not (close > ma50)
trend_val = t_stk ? 1.0 : t_50 ? 0.6 : t_200 ? -0.4 : -1.0

rsi14     = ta.rsi(close, 14)
r_sweet   = rsi14 >= 50 and rsi14 <= 65
r_mid     = (rsi14 >= 40 and rsi14 < 50) or (rsi14 > 65 and rsi14 <= 70)
r_low     = rsi14 >= 30 and rsi14 < 40
rsi_val   = r_sweet ? 1.0 : r_mid ? 0.5 : r_low ? 0.0 : rsi14 > 70 ? -0.5 : -0.7

avg30     = ta.sma(volume, 30)
rvol      = avg30 > 0 ? volume / avg30 : 1.0
pup       = close > open
rv_hi     = rvol > 1.5 and pup
rv_mid    = rvol >= 1.0 and rvol <= 1.5 and pup
rvol_val  = rv_hi ? 0.8 : rv_mid ? 0.4 : rvol < 0.7 ? -0.5 : 0.0

spy    = request.security("AMEX:SPY", timeframe.period, close,
     ignore_invalid_symbol = true)
c30    = nz(close[30], close)
s30    = nz(spy[30], spy)
sr30   = c30 > 0 ? (close - c30) / c30 * 100 : 0.0
sr30spy = s30 > 0 ? (spy - s30) / s30 * 100 : 0.0
rsdiff = sr30 - sr30spy
rs_val = rsdiff >= 10 ? 1.0 : rsdiff >= 5 ? 0.5 :
         rsdiff >= -5 ? 0.0 : rsdiff >= -10 ? -0.5 : -1.0

hi52   = ta.highest(high, 252)
dpct   = hi52 > 0 ? (hi52 - close) / hi52 * 100 : 0.0
dist_val = dpct <= 5 ? 1.0 : dpct <= 10 ? 0.5 :
           dpct <= 20 ? 0.0 : dpct <= 35 ? -0.5 : -1.0

cf_tot = (trend_val + rsi_val + rvol_val + rs_val + dist_val) * cmul
cf_pos = ((trend_val > 0 ? 1 : 0) + (rsi_val > 0 ? 1 : 0) +
          (rvol_val > 0 ? 1 : 0) + (rs_val > 0 ? 1 : 0) +
          (dist_val > 0 ? 1 : 0))
cf_neg = ((trend_val < 0 ? 1 : 0) + (rsi_val < 0 ? 1 : 0) +
          (rvol_val < 0 ? 1 : 0) + (rs_val < 0 ? 1 : 0) +
          (dist_val < 0 ? 1 : 0))

// --- FOOTPRINT DETECTORS ---──────────────────────────────────────────────────
atr14 = ta.atr(14)

in_sess  = session.ismarket
ss       = in_sess and not nz(in_sess[1], false)
var int sbar = na
if ss
    sbar := 0
else if in_sess
    sbar := nz(sbar, 0) + 1

bsec     = timeframe.in_seconds()
tsb      = bsec > 0 ? int(math.floor(390 * 60 / bsec)) : 0
savg     = ta.sma(volume, math.max(tsb, 5))
atrd     = request.security(syminfo.tickerid, "D", ta.atr(14),
     ignore_invalid_symbol = true, lookahead = barmerge.lookahead_off)

// 1. Volume Absorption
fp_abs = 0.0
if i_abs
    if volume > 1.5 * avg30 and math.abs(close - open) < 0.5 * atr14
         and atr14 > 0
        fp_abs := math.min(math.min(rvol / 1.5, 3.0) / 3.0 * 100, 100)

// 2. End-of-Day Volume Surge
fp_eod = 0.0
is_eod = timeframe.isintraday and bsec <= 3600
if i_eod and is_eod and in_sess and tsb > 0
    bl = tsb - nz(sbar, 0)
    if bl * bsec <= 30 * 60 and bl >= 0 and savg > 0 and volume > 2 * savg
        fp_eod := math.min(volume / savg / 2.0 * 100, 100)

// 3. VWAP Magnetism
vw      = ta.vwap
vn      = math.abs(close - vw) < 0.3 * atr14
vvol    = volume > 1.2 * avg30
var int vbars = 0
vbars  := vn and vvol ? vbars + 1 : 0
fp_vwap = 0.0
if i_vwap and vbars >= 5
    fp_vwap := math.min(30.0 + (vbars - 5) / 15.0 * 70.0, 100.0)

// 4. Volume-at-Price Clustering
fp_vap = 0.0
if i_vap
    rng10 = ta.highest(high, 10) - ta.lowest(low, 10)
    a100  = ta.sma(volume, 100)
    v10   = math.sum(volume, 10)
    if atr14 > 0 and a100 > 0 and rng10 < 1.5 * atr14
         and v10 > 2.0 * a100 * 10
        fp_vap := math.min(
             (1.5 * atr14) / math.max(rng10, atr14 * 0.1)
             * (v10 / (a100 * 10) / 2.0) * 30.0, 100.0)

// 5. Opening Range Stuffing
fp_orn = 0.0
is_or  = timeframe.isintraday and bsec <= 1800
if i_orn and is_or and in_sess
    base = avg30 > 0 ? avg30 : 1.0
    if nz(sbar, 0) * bsec <= 15 * 60 and not na(atrd) and atrd > 0
         and volume > 2 * base and (high - low) < atrd / 4.0
        fp_orn := math.min(volume / base / 2.0 * 100, 100)

// 6. Up/Down Tick Imbalance (signed)
fp_tick = 0.0
if i_tick
    uv    = close > open ? volume : 0.0
    dv    = close < open ? volume : 0.0
    su    = math.sum(uv, 20)
    sd    = math.sum(dv, 20)
    rat   = sd > 0 ? su / sd : (su > 0 ? 10.0 : 1.0)
    if rat > 1.8
        fp_tick :=  math.min(50.0 + (rat - 1.8) / 2.0 * 100.0, 100.0)
    else if rat < 0.55
        fp_tick := -math.min(50.0 + (0.55 - rat) / 0.4 * 100.0, 100.0)

// --- TIDEFLOW SCORE ---───────────────────────────────────────────────────────
ustr = (fp_abs  * WA
     +  fp_eod  * WE
     +  fp_vwap * WV
     +  fp_vap  * WP
     +  fp_orn  * WO)

dir  = math.abs(fp_tick) >= 25 ? math.sign(fp_tick) :
       close > ma50 ? 1 : close < ma50 ? -1 : 0

tscore = math.max(math.min(
     (ustr * dir + fp_tick * WT) * 0.6 + cf_tot * 8.0,
     100.0), -100.0)

fa = fp_abs  >= 50
fe = fp_eod  >= 50
fv = fp_vwap >= 50
fp = fp_vap  >= 50
fo = fp_orn  >= 50
ft = math.abs(fp_tick) >= 50
fc = (fa?1:0)+(fe?1:0)+(fv?1:0)+(fp?1:0)+(fo?1:0)+(ft?1:0)

// --- STATE MACHINE ---────────────────────────────────────────────────────────
mbear  = rsi14 > 75 or (close < open and rvol > 1.5)
ec     = tscore > ethr and cf_pos >= 3
wc     = tscore > wthr and cf_pos >= 2
xc     = tscore < xthr
cc     = tscore < cthr or (tscore > 0 and mbear)
state  = ec ? "ENTRY" : wc ? "WATCH" : xc ? "EXIT" : cc ? "CAUTION" : "WAIT"

var string pstate = "WAIT"
schg   = state != pstate
jent   = state == "ENTRY" and pstate != "ENTRY"
jex    = state == "EXIT"  and pstate != "EXIT"
pstate := state

// --- OSCILLATOR ---──────────────────────────────────────────────────────────
hc = tscore >= 0 ? C_HP : C_HN
plot(i_shosc ? tscore : na, "Tideflow Score",
     color = hc, style = plot.style_columns, linewidth = 2)

hld = i_shosc ? display.all : display.none
l0   = hline(   0, "0",    color = C_HAIR,                  linestyle = hline.style_solid,  display = hld)
l50  = hline(  50, "+50",  color = color.new(C_BULL, 65),   linestyle = hline.style_dotted, display = hld)
ln50 = hline( -50, "-50",  color = color.new(C_BEAR, 50),   linestyle = hline.style_dotted, display = hld)
l100 = hline( 100, "+100", color = color.new(C_HAIR, 50),   linestyle = hline.style_dotted, display = hld)
ln1  = hline(-100, "-100", color = color.new(C_HAIR, 50),   linestyle = hline.style_dotted, display = hld)
fill(l50,  l100, color = color.new(C_BULL, 92), title = "Bull zone")
fill(ln50, ln1,  color = color.new(C_BEAR, 80), title = "Bear zone")

// --- ENTRY ZONES ---──────────────────────────────────────────────────────────
var box[]   zb = array.new<box>()
var label[] zl = array.new<label>()
MZ = 20
f_clean() =>
    while array.size(zb) > MZ
        box.delete(array.shift(zb))
    while array.size(zl) > MZ
        label.delete(array.shift(zl))

if i_shzon and (jent or jex) and barstate.isconfirmed
    bull    = jent
    hic     = math.abs(tscore) > 75  and (bull ? cf_pos : cf_neg) >= 3
    mic     = math.abs(tscore) >= 60 and (bull ? cf_pos : cf_neg) >= 2
    zfill   = bull ? (hic ? C_ZHI : C_ZMD) : (hic ? C_ZBH : C_ZBM)
    zbord   = bull and hic ? C_ZBD :
              not bull and hic ? C_BEAR :
              color.new(color.black, 100)
    zbw     = bull and hic ? 1 : 0
    zh      = math.max(high, nz(high[1],high), nz(high[2],high))
    zlo     = math.min(low,  nz(low[1], low),  nz(low[2], low))
    nb = box.new(
         left = bar_index - 2, top = zh,
         right = bar_index + 8, bottom = zlo,
         border_color = zbord, border_width = zbw,
         bgcolor = zfill, force_overlay = true)
    array.push(zb, nb)
    stk  = fp_tick > 0 ? "TICK IMBAL +" : "TICK IMBAL -"
    sfl  = bull ? "FLOW LONG" : "FLOW SHORT"
    stp  = fa ? "ABSORPTION" : fp ? "VAP CLUSTER" : fv ? "VWAP MAGNET" :
           fe ? "EOD SURGE" : fo ? "OPEN STUFF" : ft ? stk : sfl
    ctg  = hic ? "HIGH" : mic ? "MED" : "LOW"
    ts   = str.format_time(time, "yyyy-MM-dd HH:mm", syminfo.timezone)
    txt  = stp + " | " + ctg + "\n" + str.tostring(tscore,"#") + " | " + ts
    nl = label.new(
         x = bar_index, y = bull ? zh : zlo,
         text = txt,
         style = bull ? label.style_label_down : label.style_label_up,
         color = bull ? color.new(C_BULL,20) : color.new(C_BEAR,20),
         textcolor = #ffffff, size = size.small,
         force_overlay = true)
    array.push(zl, nl)
    f_clean()

// --- DASHBOARD ---───────────────────────────────────────────────────────────
dpos = i_dpos == "top-right" ? position.top_right :
       i_dpos == "top-left" ? position.top_left :
       i_dpos == "bottom-right" ? position.bottom_right :
       position.bottom_left

var table dash = table.new(dpos, 2, 9,
     bgcolor = C_BG, border_width = 1,
     border_color = C_HAIR, frame_color = C_HAIR, frame_width = 1)

sc = state=="ENTRY" ? C_BULL : state=="WATCH" ? color.new(C_BULL,30) :
     state=="EXIT" ? C_BEAR : state=="CAUTION" ? color.new(C_BEAR,20) : C_SEC
nc = tscore > ethr ? C_BULL : tscore > wthr ? color.new(C_BULL,30) :
     tscore < xthr ? C_BEAR : tscore < cthr ? color.new(C_BEAR,20) : C_PRI

var int   lzb  = na
var float lzm  = na
var bool  lzbu = false
if jent or jex
    lzb  := bar_index
    lzm  := (high + low) / 2.0
    lzbu := jent
bag  = na(lzb) ? na : bar_index - lzb
zpl  = na(lzm) ? na : (close-lzm)/lzm*100*(lzbu?1:-1)

if i_shdsh and barstate.islast
    table.cell(dash,0,0,"TYDEFLOW FLOW",
         text_color=C_BULL, bgcolor=C_BG,
         text_size=size.small, text_halign=text.align_left)
    table.cell(dash,1,0,syminfo.ticker,
         text_color=C_SEC, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_right)
    table.cell(dash,0,1,"Score",
         text_color=C_SEC, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash,1,1,str.tostring(tscore,"#"),
         text_color=nc, bgcolor=C_BG,
         text_size=size.large, text_halign=text.align_right)
    table.cell(dash,0,2,"Signal",
         text_color=C_SEC, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash,1,2,state,
         text_color=sc, bgcolor=C_BG,
         text_size=size.normal, text_halign=text.align_right)
    table.cell(dash,0,3,"Confluence",
         text_color=C_SEC, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash,1,3,str.tostring(cf_pos)+" / 5",
         text_color=C_PRI, bgcolor=C_BG,
         text_size=size.small, text_halign=text.align_right)
    fpt = (fa?"ABS ":"")+(fe?"EOD ":"")+(fv?"VWP ":"")
         +(fp?"VAP ":"")+(fo?"OPN ":"")
         +(ft?(fp_tick>0?"TCK+":"TCK-"):"")
    fpt := fpt=="" ? "--" : fpt
    table.cell(dash,0,4,"Footprints",
         text_color=C_SEC, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash,1,4,fpt,
         text_color=fc>0?C_BULL:C_TER, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_right)
    table.cell(dash,0,5,"RSI / RVol",
         text_color=C_SEC, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash,1,5,
         str.tostring(rsi14,"#.0")+" / "+str.tostring(rvol,"#.0")+"x",
         text_color=C_PRI, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_right)
    table.cell(dash,0,6,"RS / 52wH",
         text_color=C_SEC, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash,1,6,
         str.tostring(rsdiff,"+#.0;-#.0")+"% / -"+str.tostring(dpct,"#.0")+"%",
         text_color=C_PRI, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_right)
    zplstr = str.tostring(zpl, "+#.0;-#.0")
    lzt = na(bag) ? "--" : str.tostring(bag) + " bars / " + zplstr + "%"
    table.cell(dash,0,7,"Last zone",
         text_color=C_SEC, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash,1,7,lzt,
         text_color=C_TER, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_right)
    table.cell(dash,0,8,"tydeflow.io",
         text_color=C_TER, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_left)
    table.cell(dash,1,8,"v1.0",
         text_color=C_TER, bgcolor=C_BG,
         text_size=size.tiny, text_halign=text.align_right)

// --- ALERTS ---───────────────────────────────────────────────────────────────
alertcondition(jent and i_alent, title = "TF Flow - ENTRY",
     message = "Tydeflow ENTRY {{ticker}} ({{interval}}) {{plot_0}}")
alertcondition(jex  and i_alex,  title = "TF Flow - EXIT",
     message = "Tydeflow EXIT {{ticker}} ({{interval}}) {{plot_0}}")
alertcondition(schg and i_alst,  title = "TF Flow - State",
     message = "Tydeflow state change {{ticker}} ({{interval}}) {{plot_0}}")
